# Copy to .env and edit. config.example.php reads these same names via getenv() for bare-metal too.

# Interprets cron.* hours/day below; storage stays UTC regardless.
TZ=UTC

# This app's own public base URL; feed URL, callbacks, and routing all derive from it.
APP_URL=https://example.com/

DB_DRIVER=sqlite
DB_PATH=/app/db/myvideofeed.sqlite
# DB_HOST=database
# DB_PORT=3306
# DB_NAME=myvideofeed  # also seeds the `database` compose service's bootstrap db/user/password
# DB_USER=myvideofeed
# DB_PASS=change-me

# Optional: YouTube Data API v3 key (duration + viewability enrichment).
YOUTUBE_API_KEY=

FEED_TITLE=My Video Feed

# Subscriber (inbound): subscribe via PubSubHubbub. Set SUBSCRIBER_URL to enable; leave empty for poll-only.
# SUBSCRIBER_URL=https://pubsubhubbub.appspot.com/subscribe
SUBSCRIBER_TOPIC_BASE=https://www.youtube.com/xml/feeds/videos.xml?channel_id=
SUBSCRIBER_LEASE_SECONDS=604799

# Publisher (outbound): notify a hub (e.g. Superfeedr's free hosted hub) that the feed changed.
# Set PUBLISHER_URL to enable; it's also declared in the feed as its <link rel="hub">.
PUBLISHER_URL=

FILTER_MIN_DURATION_SECONDS=30
FILTER_DETECT_SHORTS=false
FILTER_STRIP_PATTERNS=
FILTER_MAX_TITLE_LENGTH=78
# Pipe-separated tags to exclude, e.g. live stream|premiere (needs YOUTUBE_API_KEY)
FILTER_EXCLUDE_TAGS=
FILTER_TITLE_PREFIX=[{channel}] {title}
FILTER_UPGRADE_THUMBNAIL=false

CRON_INGEST_HOURS=9,12,15,18
CRON_SUBSCRIBE_DOW=1
CRON_SUBSCRIBE_HOUR=5

AUDIT_LOG_PATH=/app/logs/audit.log
